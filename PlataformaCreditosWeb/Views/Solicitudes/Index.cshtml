@model IEnumerable<PlataformaCreditosWeb.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="container mt-4">
    <h2>Mis Solicitudes de Crédito</h2>
    <hr />

    <form method="get" asp-action="Index" class="mb-4 p-3 bg-light border rounded">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label fw-bold">Estado</label>
                <select name="estado" class="form-select">
                    <option value="">Todos</option>
                    <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente" ? "selected" : null)">Pendiente</option>
                    <option value="Aprobado" selected="@(ViewBag.Estado == "Aprobado" ? "selected" : null)">Aprobado</option>
                    <option value="Rechazado" selected="@(ViewBag.Estado == "Rechazado" ? "selected" : null)">Rechazado</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Monto Min.</label>
                <input type="number" step="0.01" name="montoMin" class="form-control" value="@ViewBag.MontoMin" placeholder="0.00" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Monto Max.</label>
                <input type="number" step="0.01" name="montoMax" class="form-control" value="@ViewBag.MontoMax" placeholder="0.00" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Fecha Inicio</label>
                <input type="date" name="fechaInicio" class="form-control" value="@ViewBag.FechaInicio" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Fecha Fin</label>
                <input type="date" name="fechaFin" class="form-control" value="@ViewBag.FechaFin" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mt-3 mb-0 py-2">
                @Html.ValidationSummary(false, "", new { @class = "mb-0 text-danger list-unstyled" })
            </div>
        }
    </form>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Fecha de Solicitud</th>
                <th>Monto</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.MontoSolicitado.ToString("C")</td>
                        <td>
                            @if(item.Estado == "Aprobado") { <span class="badge bg-success">Aprobado</span> }
                            else if(item.Estado == "Rechazado") { <span class="badge bg-danger">Rechazado</span> }
                            else { <span class="badge bg-warning text-dark">Pendiente</span> }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Ver Detalle</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No se encontraron solicitudes con los filtros aplicados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>