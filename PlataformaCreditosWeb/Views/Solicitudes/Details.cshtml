@model PlataformaCreditosWeb.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<div class="container mt-4">
    <div class="card shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Solicitud #@Model.Id</h5>
            <span class="text-light fs-6">@Model.FechaSolicitud.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-5 text-muted">Monto Solicitado</dt>
                <dd class="col-sm-7 fw-bold fs-5 text-success">@Model.MontoSolicitado.ToString("C")</dd>

                <dt class="col-sm-5 text-muted">Estado Actual</dt>
                <dd class="col-sm-7">
                    @if(Model.Estado == "Aprobado") { <span class="badge bg-success fs-6">Aprobado</span> }
                    else if(Model.Estado == "Rechazado") { <span class="badge bg-danger fs-6">Rechazado</span> }
                    else { <span class="badge bg-warning text-dark fs-6">Pendiente</span> }
                </dd>

                @if (Model.Estado == "Rechazado" && !string.IsNullOrEmpty(Model.MotivoRechazo))
                {
                    <hr />
                    <dt class="col-sm-5 text-danger">Motivo de Rechazo</dt>
                    <dd class="col-sm-7 text-danger">@Model.MotivoRechazo</dd>
                }
            </dl>
        </div>
        <div class="card-footer bg-light text-end">
            <a asp-action="Index" class="btn btn-secondary">Volver al Catálogo</a>
        </div>
    </div>
</div>